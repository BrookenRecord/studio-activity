{
	"languages": {
		"Luau": {
			"hard_tabs": true,
			"tab_size": 4,
			"formatter": {
				"external": {
					"command": "stylua",
					"arguments": [
						"-"
					]
				}
			}
		},
		"JSON": {
			"hard_tabs": true,
			"tab_size": 4,
		},
		"JSONC": {
			"hard_tabs": true,
			"tab_size": 4,
		}
	},
	"file_types": {
		"Luau": [
			"*.lua"
		],
		"JSONC": [
			".luaurc"
		],
		"TOML": [
			"wally.lock"
		]
	},
	"lsp": {
		"luau-lsp": {
			"settings": {
				"luau-lsp": {
					"sourcemap": {
						"sourcemapFile": "plugin/generated/sourcemap.json",
						"rojoProjectFile": "plugin/generated/sourcemap.project.json",
						"generatorCommand": "rojo sourcemap plugin/generated/sourcemap.project.json --output plugin/generated/sourcemap.json --absolute --include-non-scripts"
					},
					"completion": {
						"enabled": true,
						"enableFragmentAutocomplete": false,
						"imports": {
							"enabled": true,
							"separateGroupsWithLine": true,
							"suggestRequires": true,
							"suggestServices": true,
							"requireStyle": "AlwaysAbsolute",
							"ignoreGlobs": [
								"plugin/Packages/_Index/**",
								"plugin/ServerPackages/_Index/**",
								"plugin/DevPackages/_Index/**",
							]
						}
					},
					"diagnostics": {
						"includeDependents": true,
						"workspace": false,
						"strictDatamodelTypes": true
					}
				},
				"roblox": {
					"enabled": true,
					"download_api_documentation": true,
					"download_definitions": true
				},
				"fflags": {
					"enable_by_default": true,
					"enable_new_solver": false,
					"sync": true
				}
			}
		}
	}
}
